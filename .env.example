# Database — use Supabase Postgres "Connection string" (URI), or Vercel Postgres / local Postgres
# Supabase: Project Settings → Database → Connection string (Transaction pooler or direct)
POSTGRES_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Used to encrypt JWT tokens (generate a long random string)
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Vercel Blob (from Vercel dashboard when using template storage)
BLOB_READ_WRITE_TOKEN=

# --- Grime Time (planned features; wire in code when implemented) ---
# Internal quote tools: only allowlisted staff emails (comma-separated). Quotes stay internal / feature-flagged.
# QUOTES_INTERNAL_EMAILS=bg@grimetime.local,pb@grimetime.local,de@grimetime.local
# QUOTES_INTERNAL_ENABLED=false

# EngageBay REST API key (Account → API). Never commit real values.
# ENGAGEBAY_API_KEY=
