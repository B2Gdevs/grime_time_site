# Database - Postgres URI (`payload migrate`, app runtime). This project uses `@payloadcms/db-postgres` (node `pg`).
# Supabase: prefer Direct connection (port 5432) or Session pooler for migrations / DDL.
# Transaction pooler (port 6543) can throw `XX000` / "DbHandler exited" with some workloads - if that happens, switch URI.
# Append `?sslmode=require` if your client needs it. TLS is also enabled in code for non-localhost hosts.
POSTGRES_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Used to encrypt JWT tokens (generate a long random string)
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash.
NEXT_PUBLIC_SERVER_URL=http://localhost:5465

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# First admin + CLI seed: one pair is enough. `npm run seed` uses ADMIN_* if SEED_LOGIN_* are unset.
# ADMIN_EMAIL=you@yourdomain.com
# ADMIN_PASSWORD=change-me-now
# ADMIN_NAME=Your Name
#
# Locked out of /admin? Payload users live in Postgres (POSTGRES_URL), not Supabase Auth.
# Reset or create admin: npm run admin:ensure

# Optional: different account for seed only (CI, etc.). Otherwise seed reuses ADMIN_EMAIL / ADMIN_PASSWORD.
# SEED_LOGIN_EMAIL=other-admin@yourdomain.com
# SEED_LOGIN_PASSWORD=other-password

# Transactional email (Resend) - form notifications and Payload emails. https://resend.com
# RESEND_API_KEY=re_...
# Sender must be verified in Resend (domain or onboarding@resend.dev for tests)
# EMAIL_FROM=onboarding@resend.dev
# EMAIL_FROM_NAME=Grime Time

# Supabase Storage (S3 API) - bucket name `media` (create as Public in Dashboard -> Storage)
# Project URL (Settings -> API): used to build S3 endpoint and public file URLs.
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# S3 keys: Storage -> S3 connection (enable if prompted)
# SUPABASE_S3_ACCESS_KEY_ID=
# SUPABASE_S3_SECRET_ACCESS_KEY=
# Optional overrides (defaults: bucket media, region us-east-1, endpoint = SUPABASE_URL + /storage/v1/s3)
# SUPABASE_STORAGE_BUCKET=media
# SUPABASE_S3_REGION=us-east-1
# SUPABASE_S3_ENDPOINT=

# Grime Time internal ops
# Quotes (Payload admin -> Internal): comma-separated staff emails. Must match Payload user emails.
# When set, "Seed the database" creates one admin user per address here (password changethis) - your first logins.
# When unset, seed uses bg@ / pb@ / de@ grimetime.local instead.
# QUOTES_INTERNAL_EMAILS=you@yourdomain.com,coworker@yourdomain.com
# QUOTES_INTERNAL_ENABLED=true

# EngageBay REST API key (Account -> API -> REST API Key). Used to sync Payload form submissions -> contacts.
# ENGAGEBAY_API_KEY=
# Set to false to disable sync (submissions still save in Payload).
# ENGAGEBAY_SYNC_FORM_SUBMISSIONS=true
# Optional tag on contacts created from the website form
# ENGAGEBAY_SUBMISSION_TAG=website-lead
# After contact sync, append a CRM note with all form fields (set false to skip)
# ENGAGEBAY_ATTACH_SUBMISSION_NOTE=true

# EngageBay site tracking / forms (`ehform.js` - set_account first & second args)
# Option A: two vars
# ENGAGEBAY_JS_TRACKING_KEY=l4ohdkvr3qk7elak72iq0n5a84
# ENGAGEBAY_JS_FORM_REF=gmailasyh
# Option B: single var (id|formRef)
# ENGAGEBAY_JS_TRACKING_KEY=l4ohdkvr3qk7elak72iq0n5a84|gmailasyh

# EngageHub scheduling embed (/schedule) - EhForms.create formId
# ENGAGEBAY_SCHEDULE_FORM_ID=5023843954196480

# Payload MCP server (official `@payloadcms/plugin-mcp`)
# Leave disabled until you are ready to approve and run the schema migration for MCP API keys.
# Once enabled, the normal dev server also exposes http://localhost:5465/api/mcp
# PAYLOAD_MCP_ENABLED=false
# PAYLOAD_MCP_VERBOSE_LOGS=false
# PAYLOAD_MCP_SERVER_NAME=Grime Time Payload MCP
