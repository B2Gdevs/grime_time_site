# Database - Postgres URI (`payload migrate`, app runtime). This project uses `@payloadcms/db-postgres` (node `pg`).
# Supabase: prefer Direct connection (port 5432) or Session pooler for migrations / DDL.
# Transaction pooler (port 6543) can throw `XX000` / "DbHandler exited" with some workloads - if that happens, switch URI.
# Append `?sslmode=require` if your client needs it. TLS is also enabled in code for non-localhost hosts.
POSTGRES_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Used to encrypt JWT tokens. Set this explicitly in local/dev/prod even though the app now
# derives a deterministic fallback when missing so Vercel builds do not fail during prerender.
# The fallback is only a safety net; production should still define PAYLOAD_SECRET.
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash.
NEXT_PUBLIC_SERVER_URL=http://localhost:5465

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Clerk auth (hosted sign-in/sign-up, social login, account UI)
# Use Clerk for user identity while Supabase/Postgres remains the backend database/storage layer.
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# Official Grime Time staff organization in Clerk. External members of this org bootstrap into
# first-party Grime Time staff memberships; set this when the live org id differs from the repo default.
# GRIME_TIME_CLERK_ORG_ID=org_...

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# First admin + CLI seed: one pair is enough. `npm run seed` uses ADMIN_* if SEED_LOGIN_* are unset.
# ADMIN_EMAIL=you@yourdomain.com
# ADMIN_PASSWORD=change-me-now
# ADMIN_NAME=Your Name
#
# Locked out of /admin? Payload users live in Postgres (POSTGRES_URL), not Supabase Auth.
# Reset or create admin: npm run admin:ensure

# Optional: different account for seed only (CI, etc.). Otherwise seed reuses ADMIN_EMAIL / ADMIN_PASSWORD.
# SEED_LOGIN_EMAIL=other-admin@yourdomain.com
# SEED_LOGIN_PASSWORD=other-password
#
# When `true`, `npm run seed` skips demo CRM/billing fixtures (`src/endpoints/seed/demo-seed.ts`).
# Default is to include demo data. Use `npm run seed:baseline` instead of setting this, if you prefer.
# SEED_SKIP_DEMO=true

# Transactional email (Resend) - form notifications and Payload emails. https://resend.com
# RESEND_API_KEY=re_...
# Sender must be verified in Resend (for example hello@grimetime.app)
# EMAIL_FROM=hello@grimetime.app
# EMAIL_FROM_NAME=Grime Time
# Optional shared employee inboxes for inbound lead and quote alerts. When unset, Grime Time falls back to the lead owner or admin staff users.
# EMPLOYEE_NOTIFICATION_EMAILS=ops@grimetime.app,quotes@grimetime.app

# Supabase Storage (S3 API) - bucket name `media` (create as Public in Dashboard -> Storage)
# Project URL (Settings -> API): used to build S3 endpoint and public file URLs.
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# S3 keys: Storage -> S3 connection (enable if prompted)
# SUPABASE_S3_ACCESS_KEY_ID=
# SUPABASE_S3_SECRET_ACCESS_KEY=
# Optional overrides (defaults: bucket media, region us-east-1, endpoint = SUPABASE_URL + /storage/v1/s3)
# SUPABASE_STORAGE_BUCKET=media
# SUPABASE_S3_REGION=us-east-1
# SUPABASE_S3_ENDPOINT=

# Grime Time internal ops
# When true, only Payload admins may use the customer portal routes (/ops, /dashboard, /docs in (portal)).
# Non-admins are redirected to the marketing site (?portal=staff-only).
# PORTAL_ADMIN_ONLY=false

# Optional: email for the seeded non-admin preview user (customer portal / impersonation checks). Defaults to test_user@grimetime.app.
# PORTAL_PREVIEW_TEST_USER_EMAIL=test_user@grimetime.app

# Quotes (Payload admin -> Internal): comma-separated staff emails. Must match Payload user emails.
# When set, "Seed the database" creates one admin user per address here (password changethis) - your first logins.
# When unset, seed uses bg@grimetime.app, pb@grimetime.app, de@grimetime.app.
# QUOTES_INTERNAL_EMAILS=bg@grimetime.app,pb@grimetime.app,de@grimetime.app
# QUOTES_INTERNAL_ENABLED=true

# Stripe billing / payments
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_ACCOUNT_ID=acct_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Internal lifecycle automation
# Use Payload jobs plus Resend delivery for reminders and follow-up sequences.
# CRON_SECRET is required for server-triggered jobs.

# Payload MCP server (official `@payloadcms/plugin-mcp`)
# Leave disabled until you are ready to approve and run the schema migration for MCP API keys.
# Once enabled, the normal dev server also exposes http://localhost:5465/api/mcp
# Local `npm run dev` now forces MCP off unless `GRIMETIME_DEV_ENABLE_MCP=true` is set for that session.
# PAYLOAD_MCP_ENABLED=false
# PAYLOAD_MCP_VERBOSE_LOGS=false
# PAYLOAD_MCP_SERVER_NAME=Grime Time Payload MCP
# Paste the key from Payload Admin → MCP API keys (same value for Cursor `.cursor/mcp.json` via scripts/payload-mcp-stdio.mjs)
# PAYLOAD_MCP_API_KEY=
# Optional override if the dev server is not on localhost:5465
# PAYLOAD_MCP_URL=http://localhost:5465/api/mcp

# Image generation MCP (vendored at vendor/image-gen-mcp)
# When true, `npm run dev` also starts the local image-generation MCP server using the root `.env`.
# Local `npm run dev` now forces this off unless `GRIMETIME_DEV_ENABLE_MCP=true` is set for that session.
# Use `npm run image-mcp:setup` once after cloning or submodule updates.
# IMAGE_GEN_MCP_ENABLED=false

# Ops dashboard (admin-only)
# OPENAI_API_KEY=sk-proj-1234567890
# Optional override for `npm run generate:marketing-images` and admin Prompt→Media
# OPENAI_IMAGE_MODEL=gpt-image-1
# Prompts and asset list: src/lib/media/image-generation-manifest.ts

# Internal employee copilot (staff-only beta)
# Uses the Grime Time staff portal plus approved internal docs.
# AI_OPS_ASSISTANT_ENABLED=false
# Emergency off switch even when the feature flag is on.
# AI_OPS_ASSISTANT_KILL_SWITCH=false
# Optional chat-model override (defaults to gpt-4o-mini).
# AI_OPS_ASSISTANT_MODEL=gpt-4o-mini
# Rate limiting is per authenticated staff user.
# AI_OPS_ASSISTANT_RATE_LIMIT_MAX_REQUESTS=12
# AI_OPS_ASSISTANT_RATE_LIMIT_WINDOW_MS=300000
# Sanitized audit logging only; no raw prompt or transcript body is logged.
# AI_OPS_ASSISTANT_AUDIT_LOGGING=true
# Internal-doc retrieval defaults to cheap local embeddings to stay close to the portfolio baseline.
# RAG_EMBEDDING_PROVIDER=local
# RAG_LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
# RAG_LOCAL_EMBEDDING_DIMENSIONS=384
# Optional local dev cache path for incremental doc embeddings.
# AI_OPS_ASSISTANT_CACHE_PATH=.cache/ai/ops-doc-rag.json

# =============================================================================
# Provider Configuration
# =============================================================================
# OpenAI Provider (default enabled)
PROVIDERS__OPENAI__API_KEY=sk-your-openai-api-key-here
PROVIDERS__OPENAI__BASE_URL=https://api.openai.com/v1
PROVIDERS__OPENAI__ORGANIZATION=org-your-org-id
PROVIDERS__OPENAI__TIMEOUT=300.0
PROVIDERS__OPENAI__MAX_RETRIES=3
PROVIDERS__OPENAI__ENABLED=true

# Gemini Provider (requires Vertex AI setup)
# For Imagen models, use path to Google Cloud service account JSON file
PROVIDERS__GEMINI__API_KEY=/path/to/your/vertex-ai-key.json
PROVIDERS__GEMINI__BASE_URL=https://us-central1-aiplatform.googleapis.com/v1
PROVIDERS__GEMINI__TIMEOUT=300.0
PROVIDERS__GEMINI__MAX_RETRIES=3
PROVIDERS__GEMINI__ENABLED=false
PROVIDERS__GEMINI__DEFAULT_MODEL=imagen-4

# =============================================================================
# Image Generation Settings
# =============================================================================
IMAGES__DEFAULT_MODEL=gpt-image-1
IMAGES__DEFAULT_QUALITY=auto
IMAGES__DEFAULT_SIZE=1536x1024
IMAGES__DEFAULT_STYLE=vivid
IMAGES__DEFAULT_MODERATION=auto
IMAGES__DEFAULT_OUTPUT_FORMAT=png
# Base URL for image hosting (e.g., https://cdn.example.com for nginx/CDN)
IMAGES__BASE_HOST=

# =============================================================================
# Server Configuration
# =============================================================================
SERVER__NAME=Image Gen MCP Server
SERVER__VERSION=0.1.0
SERVER__PORT=3001
SERVER__HOST=127.0.0.1
SERVER__LOG_LEVEL=INFO
SERVER__RATE_LIMIT_RPM=50

# =============================================================================
# Storage Configuration
# =============================================================================
STORAGE__BASE_PATH=./storage
STORAGE__RETENTION_DAYS=30
STORAGE__MAX_SIZE_GB=10.0
STORAGE__CLEANUP_INTERVAL_HOURS=24

# =============================================================================
# Cache Configuration
# =============================================================================
CACHE__ENABLED=true
CACHE__TTL_HOURS=24
CACHE__BACKEND=memory
CACHE__MAX_SIZE_MB=500
# CACHE__REDIS_URL=redis://localhost:6379
