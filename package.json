{
  "name": "grime_time_site",
  "version": "1.0.0",
  "description": "Grime Time — Payload website (with-vercel-website template)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "grimetime": "./bin/grimetime.mjs"
  },
  "scripts": {
    "gad": "node ../get-anything-done/bin/gad.cjs",
    "planning": "node ../get-anything-done/bin/gad.cjs",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build --webpack",
    "admin:ensure": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/ensure-admin.ts",
    "bootstrap:admin": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/bootstrap-admin.ts",
    "grimetime": "cross-env NODE_OPTIONS=--no-deprecation tsx src/cli/grimetime.ts",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/seed.ts",
    "seed:baseline": "cross-env SEED_SKIP_DEMO=true NODE_OPTIONS=--no-deprecation tsx scripts/seed.ts",
    "ai:ops:ingest": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/ai-ops-ingest.ts",
    "generate:marketing-images": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/generate-marketing-images.ts",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "node scripts/dev-with-services.mjs",
    "dev:3000": "cross-env GT_DEV_PORT=3000 node scripts/dev-with-services.mjs",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && npm run build && npm run start",
    "image-mcp:setup": "node scripts/image-gen-mcp-setup.mjs",
    "image-mcp:start": "node scripts/image-gen-mcp-start.mjs --transport streamable-http --cors",
    "image-mcp:stdio": "node scripts/image-gen-mcp-start.mjs --transport stdio",
    "verify:mcp": "node scripts/verify-mcp.mjs",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "block-lab:build": "npm --prefix tools/grime-block-lab run build",
    "block-lab:dev": "npm --prefix tools/grime-block-lab run dev",
    "block-lab:export": "npm --prefix tools/grime-block-lab run export",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm -f package-lock.json && npm install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "npm run test:int && npm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "ci": "payload migrate && npm run build"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.21",
    "@clerk/nextjs": "^7.0.8",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@payloadcms/admin-bar": "3.79.1",
    "@payloadcms/db-postgres": "3.79.1",
    "@payloadcms/email-resend": "^3.79.1",
    "@payloadcms/live-preview-react": "3.79.1",
    "@payloadcms/next": "3.79.1",
    "@payloadcms/plugin-form-builder": "3.79.1",
    "@payloadcms/plugin-mcp": "^3.79.1",
    "@payloadcms/plugin-nested-docs": "3.79.1",
    "@payloadcms/plugin-redirects": "3.79.1",
    "@payloadcms/plugin-search": "3.79.1",
    "@payloadcms/plugin-seo": "3.79.1",
    "@payloadcms/richtext-lexical": "3.79.1",
    "@payloadcms/storage-s3": "^3.79.1",
    "@payloadcms/ui": "3.79.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^2.0.1",
    "@xenova/transformers": "^2.17.2",
    "boxen": "^8.0.1",
    "citty": "^0.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "16.4.7",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "lucide-react": "^0.563.0",
    "motion": "^12.38.0",
    "next": "16.2.0",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "payload": "3.79.1",
    "picocolors": "^1.1.1",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.1",
    "react-joyride": "^3.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.4",
    "remark-gfm": "^4.0.1",
    "sharp": "0.34.2",
    "sonner": "^2.0.7",
    "stripe": "^18.4.0",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@iarna/toml": "^2.2.5",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "16.3.0",
    "@types/escape-html": "^1.0.2",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.4.19",
    "commander": "^12.1.0",
    "ejs": "^3.1.10",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.0",
    "fast-xml-parser": "^4.5.0",
    "jsdom": "28.0.0",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
