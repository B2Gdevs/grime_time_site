# Optional: enable the AI-powered SDK Guide in the workbench.
# (Used by `app/api/sdk-guide/*`.)
OPENAI_API_KEY=

# Optional: origin for the local Grime Time app when using the Live tab.
# The lab proxies `GET /api/internal/block-lab/blocks` through this origin.
GRIME_TIME_APP_ORIGIN=http://127.0.0.1:3000
